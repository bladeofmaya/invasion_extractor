<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Invasion Extractor</title>
  <link rel="stylesheet" href="/app.css">
</head>
<body>
  <header>
    <div class="tabs" id="tabs">
      <div class="tab active" onclick="switchView('all')">All Clips</div>
      <div class="tab" onclick="switchView('groups')">Groups</div>
    </div>
    <button class="back-btn" id="back-btn" onclick="goBack()" style="display:none">&larr; Back</button>
    <div class="tool-name" style="margin-left: auto; font-size: 1.1rem; font-weight: 700; color: var(--color-accent); letter-spacing: 0.02em;">Invasion Studio</div>
  </header>

  <main>
    <div class="clip-panel" id="clip-panel">
      <div class="clip-panel-header">
        <h2 id="panel-title">All Clips</h2>
        <div class="filter-dropdown" id="filter-dropdown">
          <select id="clip-filter" onchange="setFilter(this.value)">
            <option value="everything">Everything</option>
            <option value="unassigned">Unassigned</option>
            <option value="assigned">Assigned</option>
            <option value="deleted">Deleted</option>
          </select>
        </div>
        <div id="group-export-controls" class="export-area" style="display:none">
          <input type="text" id="export-filename" placeholder="combined (optional)">
          <button class="primary" onclick="exportGroup()">Export</button>
        </div>
      </div>
      <div class="clip-list" id="clip-list"></div>
      <div class="group-grid" id="group-grid" style="display:none">
        <div class="group-card new-group-card" id="new-group-card" onclick="showNewGroupFormInline()">
          <div class="name" style="color:var(--text-secondary); text-align:center; margin:8px 0">+ New Group</div>
        </div>
        <div id="new-group-inline-form" style="display:none; grid-column:1 / -1; margin-bottom:16px;">
          <div class="new-group-form" style="display:flex; gap:8px;">
            <input type="text" id="new-group-name" placeholder="Group name" onkeydown="if(event.key==='Enter')createGroup()">
            <button onclick="createGroup()">Add</button>
            <button class="secondary" onclick="cancelNewGroupInline()">Cancel</button>
          </div>
        </div>
      </div>
    </div>

    <div class="preview-panel" id="preview-panel">
      <div class="editor">
        <div class="editor-header">
          <input type="text" id="title-input" placeholder="Clip title (optional)" disabled onblur="saveTitle()" style="background: var(--input-bg); color: var(--text-primary); border: 1px solid var(--input-border); border-radius: 4px; padding: 4px 10px; font-size: 0.9rem; flex: 1; min-width: 0; margin-right: 10px;">
          <button id="delete-btn" class="danger delete-btn-small" onclick="deleteSelected()" style="display:none">Delete</button>
          <button id="restore-btn" class="secondary delete-btn-small" onclick="restoreSelected()" style="display:none">Restore</button>
        </div>
        <textarea id="note-input" placeholder="Add a note about this clip..." disabled onblur="saveNote()"></textarea>
        <div class="meta">
          <div class="star-rating" id="editor-rating" onclick="event.stopPropagation()"></div>
          <div class="result-toggle" id="editor-result">
            <label class="result-win">
              <input type="radio" name="result" value="win" onchange="setResult('win')"> Win
            </label>
            <label class="result-loss">
              <input type="radio" name="result" value="loss" onchange="setResult('loss')"> Loss
            </label>
            <label class="result-dc">
              <input type="radio" name="result" value="dc" onchange="setResult('dc')"> DC
            </label>
            <label>
              <input type="radio" name="result" value="" onchange="setResult('')"> None
            </label>
          </div>
        </div>
        <div class="editor-actions">
          <div class="status" id="save-status"></div>
        </div>
      </div>
      <div class="video-wrapper" id="video-wrapper">
        <div class="placeholder">Select a clip to preview</div>
      </div>
      <div class="video-controls" id="video-controls" style="display:none;">
        <div class="video-meta-row">
          <div class="audio-track-select">
            <label>Audio:</label>
            <select id="audio-track" onchange="changeAudioTrack()">
              <option value="1">Track 1</option>
              <option value="2">Track 2</option>
              <option value="3">Track 3</option>
              <option value="4" selected>Track 4</option>
            </select>
          </div>
          <div class="file-link" onclick="openClipFile()" title="Click to open in external player">File: <span id="meta-filename">—</span></div>
        </div>
        <div class="cut-row">
          <button class="secondary" onclick="markCutStart()">[ Mark</button>
          <button class="secondary" onclick="markCutEnd()">] End</button>
          <button class="secondary" onclick="clearCuts()">Clear</button>
          <div class="cut-timeline" id="cut-timeline"></div>
        </div>
        <div class="cut-list-inline" id="cut-list"></div>
      </div>
    </div>
  </main>

  <script src="/app.js"></script>
</body>
</html>
