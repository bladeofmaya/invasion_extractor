<div class="editor" data-controller="editor" data-editor-clip-id-value="">
  <div class="editor-header">
    <input type="text" id="title-input" data-editor-target="titleInput" placeholder="Clip title (optional)" disabled data-action="blur->editor#saveTitle">
    <button id="delete-btn" class="danger delete-btn-small" data-editor-target="deleteBtn" data-action="click->editor#deleteClip" style="display:none">Delete</button>
    <button id="restore-btn" class="secondary delete-btn-small" data-editor-target="restoreBtn" data-action="click->editor#restoreClip" style="display:none">Restore</button>
  </div>
  <textarea id="note-input" data-editor-target="noteInput" placeholder="Add a note about this clip..." disabled data-action="blur->editor#saveNote"></textarea>
  <div class="meta">
    <div class="star-rating" id="editor-rating" data-editor-target="ratingContainer" data-action="click->editor#setRating">
      <span class="star" data-value="1">★</span>
      <span class="star" data-value="2">★</span>
      <span class="star" data-value="3">★</span>
      <span class="star" data-value="4">★</span>
      <span class="star" data-value="5">★</span>
    </div>
    <div class="result-toggle" id="editor-result" data-editor-target="resultContainer" data-action="change->editor#setResult">
      <label class="result-win">
        <input type="radio" name="result" value="win"> Win
      </label>
      <label class="result-loss">
        <input type="radio" name="result" value="loss"> Loss
      </label>
      <label class="result-dc">
        <input type="radio" name="result" value="dc"> DC
      </label>
      <label>
        <input type="radio" name="result" value=""> None
      </label>
    </div>
  </div>
  <div class="editor-actions">
    <div class="status" id="save-status" data-editor-target="saveStatus"></div>
  </div>
</div>
