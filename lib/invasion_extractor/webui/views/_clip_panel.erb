<div class="clip-panel" id="clip-panel" data-controller="clip-list" data-clip-list-view-value="all" data-clip-list-filter-value="everything" data-clip-list-group-value="" data-clip-list-selected-clip-id-value="">
  <div class="clip-panel-header">
    <h2 id="panel-title" data-clip-list-target="panelTitle">All Clips</h2>
    <div class="filter-dropdown" id="filter-dropdown" data-clip-list-target="filterDropdown">
      <select id="clip-filter" data-clip-list-target="filterSelect" data-action="change->clip-list#setFilter">
        <option value="everything">Everything</option>
        <option value="unassigned">Unassigned</option>
        <option value="assigned">Assigned</option>
        <option value="deleted">Deleted</option>
      </select>
    </div>
    <div id="group-export-controls" class="export-area" data-clip-list-target="groupExport" style="display:none">
      <input type="text" id="export-filename" placeholder="combined (optional)">
      <button class="primary" data-action="click->clip-list#exportGroup">Export</button>
    </div>
  </div>
  <div class="clip-list" id="clip-list" data-clip-list-target="container"></div>
  <div class="group-grid" id="group-grid" data-controller="group-manager" data-group-manager-target="grid" data-navigation-target="groupGrid" style="display:none">
    <div class="group-card new-group-card" id="new-group-card" data-group-manager-target="newGroupCard" data-navigation-target="newGroupCard" data-action="click->group-manager#showNewGroupForm">
      <div class="name" style="color:var(--text-secondary); text-align:center; margin:8px 0">+ New Group</div>
    </div>
    <div id="new-group-inline-form" data-group-manager-target="newGroupForm" data-navigation-target="newGroupForm" style="display:none; grid-column:1 / -1; margin-bottom:16px;">
      <div class="new-group-form" style="display:flex; gap:8px;">
        <input type="text" id="new-group-name" data-group-manager-target="newGroupInput" placeholder="Group name" data-action="keydown->group-manager#handleNewGroupKeydown">
        <button data-action="click->group-manager#createGroup">Add</button>
        <button class="secondary" data-action="click->group-manager#cancelNewGroupForm">Cancel</button>
      </div>
    </div>
  </div>
</div>
