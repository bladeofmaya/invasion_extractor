<div class="w-1/2 h-full min-h-0 flex flex-col overflow-hidden bg-app-bg" id="clip-panel" data-controller="clip-list" data-clip-list-view-value="all" data-clip-list-filter-value="everything" data-clip-list-group-value="" data-clip-list-selected-clip-id-value="">
  <div class="px-4 py-3 border-b border-border flex justify-between items-center">
    <h2 class="m-0 text-base text-text-muted" data-clip-list-target="panelTitle">All Clips</h2>
    <div class="block" data-clip-list-target="filterDropdown" id="filter-dropdown">
      <select class="bg-input-bg text-text-primary border border-input-border px-3 py-1.5 rounded text-sm cursor-pointer focus:outline-none focus:border-input-focus-ring" data-clip-list-target="filterSelect" data-action="change->clip-list#setFilter" id="clip-filter">
        <option value="everything">Everything</option>
        <option value="unassigned">Unassigned</option>
        <option value="assigned">Assigned</option>
        <option value="deleted">Deleted</option>
      </select>
    </div>
    <div class="hidden gap-2 items-center ml-auto" data-clip-list-target="groupExport" id="group-export-controls">
      <input type="text" class="bg-input-bg text-text-primary border border-input-border px-3 py-1.5 rounded text-sm w-40" id="export-filename" placeholder="combined (optional)">
      <button class="bg-primary text-primary-fg border-none px-4 py-1.5 rounded text-sm font-semibold cursor-pointer hover:bg-primary-hover" data-action="click->clip-list#exportGroup">Export</button>
    </div>
  </div>
  <div class="flex-1 overflow-y-auto px-4 py-3 min-h-0" data-clip-list-target="container" id="clip-list"></div>
  <div class="flex-1 overflow-y-auto p-4 grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-4 content-start hidden" data-controller="group-manager" data-group-manager-target="grid" data-navigation-target="groupGrid" id="group-grid">
    <div class="border-2 border-dashed border-border bg-transparent flex items-center justify-center min-h-24 cursor-pointer hover:border-accent hover:translate-y-0" id="new-group-card" data-group-manager-target="newGroupCard" data-action="click->group-manager#showNewGroupForm">
      <div class="text-base font-medium text-text-secondary">+ New Group</div>
    </div>
    <div class="hidden col-span-full mb-4" data-group-manager-target="newGroupForm" id="new-group-inline-form">
      <div class="flex gap-2 items-center">
        <input type="text" class="bg-input-bg text-text-primary border border-input-border px-3 py-1.5 rounded text-sm w-36" data-group-manager-target="newGroupInput" placeholder="Group name" data-action="keydown->group-manager#handleNewGroupKeydown">
        <button class="bg-surface-secondary text-text-primary border border-border px-4 py-1.5 rounded text-sm cursor-pointer hover:bg-surface-hover">Add</button>
        <button class="bg-transparent border border-text-muted text-text-muted px-4 py-1.5 rounded text-sm cursor-pointer hover:border-text-primary hover:text-text-primary">Cancel</button>
      </div>
    </div>
  </div>
</div>
