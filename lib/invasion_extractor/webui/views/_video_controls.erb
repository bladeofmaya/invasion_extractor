<div class="video-controls" id="video-controls" data-video-player-target="controls" style="display:none;">
  <div class="video-meta-row">
    <div class="audio-track-select">
      <label>Audio:</label>
      <select id="audio-track" data-video-player-target="audioTrack" data-action="change->video-player#changeAudioTrack">
        <option value="1">Track 1</option>
        <option value="2">Track 2</option>
        <option value="3">Track 3</option>
        <option value="4" selected>Track 4</option>
      </select>
    </div>
    <div class="file-link" data-action="click->video-player#openFile" title="Click to open in external player">File: <span id="meta-filename" data-video-player-target="filename">—</span></div>
  </div>
  <div class="cut-row">
    <button class="secondary" data-action="click->video-player#markCutStart">[ Mark</button>
    <button class="secondary" data-action="click->video-player#markCutEnd">] End</button>
    <button class="secondary" data-action="click->video-player#clearCuts">Clear</button>
    <div class="cut-timeline" id="cut-timeline" data-video-player-target="timeline"></div>
  </div>
  <div class="cut-list-inline" id="cut-list" data-video-player-target="cutList"></div>
</div>
